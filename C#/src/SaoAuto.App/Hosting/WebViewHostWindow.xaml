<Window x:Class="SaoAuto.App.Hosting.WebViewHostWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SaoAuto WebView (placeholder)"
        Height="600"
        Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#0E1014"
        Foreground="#E8F0FE">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="SaoAuto · WebView host"
                       FontSize="28" FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Foreground="#7AC0FF" />
            <TextBlock Text="Session 4 placeholder · sao_auto/web HTML loads in Session 9"
                       FontSize="14"
                       HorizontalAlignment="Center"
                       Margin="0,12,0,0"
                       Opacity="0.75" />
            <TextBlock x:Name="StatusText"
                       FontSize="12"
                       HorizontalAlignment="Center"
                       Margin="0,16,0,0"
                       Opacity="0.6" />
        </StackPanel>
    </Grid>
</Window>
